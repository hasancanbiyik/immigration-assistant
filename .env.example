# Immigration Assistance ChatBot — Environment Variables
# =======================================================
# Copy this file to `.env` for local development (it is gitignored).
# In production (HuggingFace Space / Fly.io), set these as platform secrets
# or environment variables instead of committing a real .env file.


# ── LLM (optional but recommended) ─────────────────────────────────────────────
# Google AI Studio key for Gemini 2.5 Flash. Free tier: 15 RPM, 1M TPM.
# Get one at: https://aistudio.google.com/app/apikey
#
# Without this key the app still works — Q&A returns retrieved document chunks
# (no LLM reasoning) and translation falls back to OPUS-MT. With it, you get:
#   - LLM-synthesized Q&A answers
#   - Higher-quality translation with USCIS certification template
#   - Gemini vision OCR for scanned PDFs
#   - AI-mode RFE issue extraction
GEMINI_API_KEY=


# ── Embedding model ────────────────────────────────────────────────────────────
# Which SentenceTransformer model to use for vector embeddings.
#
# Defaults to BAAI/bge-m3 if unset — 568M params, multilingual, ~2 GB RAM,
# ~90s cold-start while the model downloads on a fresh container.
#
# For free-tier / memory-constrained hosts (HuggingFace Space free CPU,
# Fly.io shared-cpu-1x), set this to MiniLM for ~150 MB RAM and ~15s cold-start:
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2


# ── CORS (only needed if frontend lives on a different origin) ─────────────────
# Comma-separated list of additional origins to allow. By default the app
# allows http://localhost:3000 and http://localhost:5173 for local dev.
# When frontend and backend share the same origin (Docker / HF Space / Fly.io),
# leave this unset.
# Example: ALLOWED_ORIGINS=https://my-portfolio.com,https://demo.example.org
ALLOWED_ORIGINS=
